# =====================================================================
# neon-app-template — environment (gitignored; .env.example mirrors it)
# All Neon platform services used here (Auth, Data API, Object Storage,
# AI Gateway) are in Beta and currently region-limited to us-east-2.
# Console: https://console.neon.tech
# =====================================================================

# --- Database ---
# Neon console → your project → Connect → copy the connection string
DATABASE_URL=

# --- Neon Auth ---
# Neon console → your branch → Auth → enable → copy the auth base URL
NEON_AUTH_BASE_URL=
# Cookie-signing secret, minimum 32 chars. Generate: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=
# Same auth URL as above, exposed to the browser for the Data API client
NEXT_PUBLIC_NEON_AUTH_URL=

# --- Neon Data API (PostgREST-compatible; enabled per branch) ---
# Neon console → your branch → Data API → enable → copy the endpoint URL
NEXT_PUBLIC_NEON_DATA_API_URL=

# --- Neon Object Storage (S3-compatible) ---
# Create a bucket with the Neon CLI (`neon buckets create <name>`) — the
# endpoint and credentials are issued on creation. The AWS SDK reads the
# AWS_* vars automatically; the bucket name is passed in code.
AWS_ENDPOINT_URL_S3=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
AWS_S3_BUCKET=

# --- Neon AI Gateway ---
# Neon console → AI Gateway → copy the branch endpoint + create a token
NEON_AI_GATEWAY_BASE_URL=
NEON_AI_GATEWAY_TOKEN=
# Default model id, swappable: https://neon.com/docs/ai-gateway/models
NEON_AI_GATEWAY_MODEL=claude-haiku-4-5

# --- Neon management API (optional; for provisioning/automation only) ---
# Neon console → Account settings → API keys
NEON_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
